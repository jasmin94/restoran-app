// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: menu
// Fields:
//   - name: string (required)
//   - description: string (optional)
//   - price: number (required)
//   - category: string (required)
//   - image: string (required)
//
// Collection: reservations
// Fields:
//   - name: string (required)
//   - email: string (required)
//   - date: string (required)
//   - time: string (required)
//   - guests: number (required)
//   - status: string (required, enum: ['pending', 'confirmed', 'cancelled'])
//
// Collection: orders
// Fields:
//   - customerName: string (required)
//   - phone: string (required)
//   - address: string (required)
//   - type: string (required, enum: ['delivery', 'pickup'])
//   - items: list (required)
//   - total: number (required)
//   - status: string (required)
//   - createdAt: string (required)
//
// Collection: workers
// Fields:
//   - name: string (required)
//   - role: string (required)
//   - email: string (required)
//   - phone: string (required)
//   - password: string (required)
//   - joinedAt: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "jasminhalilovic122@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    // Since we are using a custom password system for workers in the UI, 
    // we can't easily verify "worker" status in rules without Firebase Auth.
    // For now, we'll allow the Admin full access and public can only create reservations/orders.
    
    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string;
    }

    function isValidReservation(data) {
      return data.name is string && data.name.size() > 0 &&
             data.email is string &&
             data.date is string &&
             data.time is string &&
             data.guests is number && data.guests > 0 &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             (!('customerUid' in data) || data.customerUid == null || (isAuthenticated() && data.customerUid == request.auth.uid));
    }

    function isValidOrder(data) {
      return data.customerName is string &&
             data.type in ['delivery', 'pickup'] &&
             data.items is list &&
             data.total is number &&
             data.status is string &&
             data.createdAt is string &&
             (!('customerUid' in data) || data.customerUid == null || (isAuthenticated() && data.customerUid == request.auth.uid));
    }

    function isValidWorker(data) {
      return data.name is string &&
             data.role in ['Konobar', 'Kuhar', 'Dostavljač', 'Menadžer'] &&
             data.email is string &&
             data.password is string &&
             data.joinedAt is string;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && 
             'customerUid' in resource.data && 
             resource.data.customerUid != null && 
             request.auth.uid == resource.data.customerUid;
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.email is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading profiles for order context
      allow write: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }

    match /menu/{itemId} {
      allow read: if true; // Public can see the menu
      allow write: if isAdmin(); // Only admin can edit menu
    }

    match /reservations/{resId} {
      allow create: if isValidReservation(request.resource.data);
      allow read, update: if isAdmin() || isDocOwner();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update: if isAdmin() || isDocOwner();
      allow delete: if isAdmin();
    }

    match /workers/{workerId} {
      allow read: if true; // Public can read to enable login (PROTOTYPE ONLY - SECURE THIS IN PRODUCTION)
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
