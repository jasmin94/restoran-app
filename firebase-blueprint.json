{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "Represents a dish in the restaurant menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "isSpecial": { "type": "boolean" },
        "promotionPrice": { "type": "number" },
        "promotionText": { "type": "string" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Represents a table reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerUid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guests": { "type": "integer" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["name", "date", "time", "guests", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a food order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerUid": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["delivery", "pickup"] },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "delivered", "cancelled"] },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "type", "items", "total", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a client profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Worker": {
      "title": "Worker",
      "description": "Represents a restaurant employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Konobar", "Kuhar", "Dostavljač", "Menadžer"] },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "joinedAt": { "type": "string" }
      },
      "required": ["name", "role", "email", "phone", "password", "joinedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Represents a customer review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerUid": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" },
        "orderId": { "type": "string" }
      },
      "required": ["customerUid", "customerName", "rating", "comment", "createdAt"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "loyaltyProgramEnabled": { "type": "boolean" },
        "loyaltyPointsPerKM": { "type": "number" },
        "restaurantName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "brandColor": { "type": "string" }
      },
      "required": ["loyaltyProgramEnabled", "loyaltyPointsPerKM", "restaurantName", "brandColor"]
    },
    "Category": {
      "title": "Category",
      "description": "A menu category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "AboutContent": {
      "title": "About Content",
      "description": "Represents the content of the About Us page",
      "type": "object",
      "properties": {
        "bs": {
          "type": "object",
          "properties": {
            "storyTitle": { "type": "string" },
            "storyText": { "type": "string" },
            "missionTitle": { "type": "string" },
            "missionText": { "type": "string" },
            "teamTitle": { "type": "string" },
            "teamText": { "type": "string" }
          }
        },
        "en": {
          "type": "object",
          "properties": {
            "storyTitle": { "type": "string" },
            "storyText": { "type": "string" },
            "missionTitle": { "type": "string" },
            "missionText": { "type": "string" },
            "teamTitle": { "type": "string" },
            "teamText": { "type": "string" }
          }
        }
      },
      "required": ["bs", "en"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image in the restaurant gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "alt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "url", "createdAt"]
    }
  },
  "firestore": {
    "menu": {
      "schema": "MenuItem",
      "description": "Collection of menu items"
    },
    "reservations": {
      "schema": "Reservation",
      "description": "Collection of table reservations"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of food orders"
    },
    "workers": {
      "schema": "Worker",
      "description": "Collection of restaurant workers"
    },
    "users": {
      "schema": "UserProfile",
      "description": "Collection of client profiles"
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of customer reviews"
    },
    "settings": {
      "schema": "AppSettings",
      "description": "Global application settings"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of menu categories"
    },
    "about": {
      "schema": "AboutContent",
      "description": "Content for the About Us page"
    },
    "gallery": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images"
    }
  }
}
